model common_system_menu {
  menu_id    Int     @id @default(autoincrement())
  menu_name  String  @db.VarChar(300)
  menu_icon  String  @default("") @db.VarChar(100)
  menu_index Int     @default(0)
  api_id     Int?
  node_type  String? @db.VarChar(2)
  parent_id  String  @default("") @db.VarChar(30)

  state      String   @default("1") @db.VarChar(5)
  updated_at DateTime @updatedAt
  created_at DateTime @default(now())

  @@map("tbl_common_system_menu")
}
