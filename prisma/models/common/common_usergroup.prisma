model common_usergroup {
    usergroup_id    Int    @id @default(autoincrement())
    organization_id Int
    usergroup_type  String @default("") @db.VarChar(3)
    usergroup_code  String @default("") @db.VarChar(20)
    usergroup_name  String @default("") @db.VarChar(50)
    node_type       String @default("") @db.VarChar(2)
    parent_id       String @default("") @db.VarChar(30)

    state      String   @db.VarChar(5)
    updated_at DateTime @updatedAt
    created_at DateTime @default(now())

    @@map("tbl_common_usergroup")
}
