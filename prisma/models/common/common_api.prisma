model common_api {
    api_id       Int    @id @default(autoincrement())
    api_type     String @default("") @db.VarChar(10)
    api_name     String @default("") @db.VarChar(300)
    api_path     String @default("") @db.VarChar(300)
    api_function String @default("") @db.VarChar(100)
    auth_flag    String @default("1") @db.VarChar(2)
    api_remark   String @default("") @db.VarChar(30)

    state      String   @default("1") @db.VarChar(5)
    updated_at DateTime @updatedAt
    created_at DateTime @default(now())

    @@map("tbl_common_api")
}
