model common_group {
    group_id   Int    @id @default(autoincrement())
    group_type String @default("") @db.VarChar(3)
    group_code String @default("") @db.VarChar(20)
    group_name String @default("") @db.VarChar(50)
    node_type  String @default("") @db.VarChar(2)
    parent_id  String @default("") @db.VarChar(30)

    state      String   @default("1") @db.VarChar(5)
    updated_at DateTime @updatedAt
    created_at DateTime @default(now())

    @@map("tbl_common_group")
}
