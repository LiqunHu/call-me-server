{
  "name": "call-me-server",
  "description": "huliqun@126.com",
  "author": "huliqun <huliqun@126.com>",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "tsx ./src/index.ts",
    "syncDB": "prisma migrate dev --schema ./prisma",
    "genPrisma": "prisma generate --schema ./prisma",
    "genSeeds": "tsx ./src/bin/initDB.ts",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "genswagger": "rimraf ./public/swagger/swagger.json && joi-swagger-generator -r -v ./services/ -h ./public/swagger/header.json -o ./public/swagger/swagger.json"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "joi": "^18.1.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.5.0",
    "supertest": "^6.3.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
