{
  "name": "call-me-server",
  "description": "huliqun@126.com",
  "author": "huliqun <huliqun@126.com>",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "tsx ./src/index.ts",
    "debug": "node --inspect=0.0.0.0:9229 --use-strict ./bin/www",
    "createTable": "tsx ./src/bin/createTable.ts",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "genswagger": "rimraf ./public/swagger/swagger.json && joi-swagger-generator -r -v ./services/ -h ./public/swagger/header.json -o ./public/swagger/swagger.json"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "joi": "^18.0.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^6.3.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
